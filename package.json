{
  "name": "osday-ospo-talk",
  "version": "1.0.0",
  "private": true,
  "description": "Open Source in Production: Why Your Company Needs an OSPO — slides for OSDay 2026",
  "scripts": {
    "build:html": "marp slides.md -o dist/slides.html --html",
    "build:pdf": "marp slides.md -o dist/slides.pdf --allow-local-files",
    "build:pptx": "marp slides.md -o dist/slides.pptx --allow-local-files",
    "build:notes": "marp slides.md -o dist/slides-notes.pdf --allow-local-files --notes",
    "build": "npm run build:html && npm run build:pdf && npm run build:notes",
    "preview": "marp slides.md --preview",
    "watch": "marp slides.md --watch --html"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.0.0"
  }
}
